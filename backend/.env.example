# Supabase connection pooler — port 6543 — used by the running app
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true
# Supabase direct connection — port 5432 — used by prisma db:push only
DIRECT_URL=postgresql://postgres:[PASSWORD]@db.tfqdsargwttdrkdmklvg.supabase.co:5432/postgres
INTERNAL_API_KEY=your-strong-random-secret
AI_SERVICE_URL=https://your-ai-service.onrender.com
ALLOWED_ORIGIN=https://your-frontend.vercel.app
SESSION_SECRET=your-strong-session-secret
UPLOAD_DIR=/tmp/uploads
PORT=4000
NODE_ENV=production
