generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // URLs are now managed in prisma.config.ts to avoid P1012 errors
}

model Candidate {
  id                 String   @id @default(uuid())
  fullName           String
  email              String   @unique
  phone              String
  currentLocation    String
  noticePeriod       String
  position           String
  currentCompany     String
  yearsExperience    Float
  currentCTC         Float
  expectedCTC        Float
  linkedInUrl        String?
  openToRelocation   Boolean  @default(false)
  resumeLink         String
  status             String   @default("UPLOADED") 
  suitabilityScore   Float?
  aiRemarks          String?  @db.Text
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}